---
import Layout from "../layouts/Layout.astro";
import profilePhoto from "../assets/img/profile.webp";
import Stats from "../components/Stats.astro";
import rodentSvg from "../assets/icons/mammals.svg";
import Background from "../components/Background.astro";
import cntl from "cntl";
import MainPage from "../components/MainPage.astro";
import PageDescription from "../components/PageDescription.astro";
import Image from "astro/components/Image.astro";
import SocialMediaIcons from "../components/SocialMediaIcons.astro";

const titleClasses = cntl`
  font-serif
  text-5xl
  text-chetwode-950
  dark:text-chetwode-50
  mt-2
`;

const heroTextClasses = cntl`
  mt-4
  text-pretty
  text-lg
  text-slate-700
  dark:text-slate-200
  sm:text-xl/8
`;

const researchSentenceClasses = cntl`
  font-serif
  font-semibold
  text-3xl
  bg-gradient-to-r
  from-porsche-600
  to-chetwode-700
  dark:from-porsche-300
  dark:to-chetwode-200
  bg-clip-text
  text-transparent
`;

const sectionTitleClasses = cntl`
  text-xl
  text-porsche-950
  dark:text-porsche-50
  text-left
  m-4
`;

const statsGridClasses = cntl`
  grid
  bg-gradient-to-r
  from-porsche-400
  to-chetwode-200
  dark:from-porsche-700
  dark:to-chetwode-600
  lg:grid-cols-3
  gap-4
  text-center
  rounded-2xl
  lg:rounded-full
  mt-16
  mx-8
  lg:mx-24
  animate-slide-in-bottom
`;

const keywordClasses = cntl`
    border-2
    border-chetwode-300
    dark:border-chetwode-400
    text-chetwode-700
    dark:text-chetwode-400
    rounded-full
    py-1
    px-4 
    text-sm
    font-semibold 
`;

const keywordList = [
  "In situ diversification",
  "Biodiversity Informatics",
  "Artificial Intelligence",
];

const buttonClasses = cntl`
  mt-12
  mx-auto
  bg-chetwode-600
  hover:bg-chetwode-900
  text-chetwode-50
  font-semibold
  py-3
  px-6
  rounded-xl
  shadow-lg
  transition
  duration-300
  ease-in-out
  hover:scale-105
  transform
  w-fit
`;
---

<Layout
  title="Island small mammals and efficient, scalable biodiversity software"
>
  <MainPage>
    <Background backgroundImage={rodentSvg} />
    <div class="text-center item-center mt-8 md:mt-16">
      <Image
        class="block mx-auto rounded-full sm:mx-auto"
        src={profilePhoto}
        height={180}
        width={180}
        loading="lazy"
        alt="Handika's profile"
      />
      <h1 class={titleClasses}>
        Hi, I'm <strong>Heru Handika</strong>
      </h1>
      <PageDescription>
        Post-Doctoral Associate · the University of Florida, USA
      </PageDescription>
      <div
        class="flex flex-wrap justify-center gap-x-2 gap-y-2 sm:gap-x-4 px-2 mt-2"
      >
        {
          keywordList.map((keyword) => (
            <div class={keywordClasses}>
              <p class="text-center">{keyword}</p>
            </div>
          ))
        }
      </div>
      <p class={heroTextClasses}>
        I study island small-mammal diversity and speciation and build open,
        scalable tools to enhance data integration, analyses, and access. My
        work combines fieldwork in remote montane forests with emerging AI
        technologies and high-performance software that scales from mobile
        devices to HPC clusters.
      </p>
    </div>
    <SocialMediaIcons />
    <div class={statsGridClasses}>
      <Stats title="Fieldwork" value="30" unit="expeditions" url="/fieldwork" />
      <Stats
        title="Specimen contribution"
        value="8k"
        unit="vouchers"
        url="/fieldwork"
      />
      <Stats title="Code written" value="500K" unit="lines" url="/software" />
    </div>
    <div id="key-approach" class="mt-16 mx-auto text-center text-pretty">
      <p class="text-porsche-950 dark:text-porsche-50 text-lg">
        I describe my work as:
      </p>
      <p class={researchSentenceClasses}>
        "An end-to-end approach to accelerate and broaden access to cutting-edge
        collection-based evolutionary studies"
      </p>
    </div>
    <!-- <div class="mt-16"></div>
    <div class="mt-16">
      <h2
        class="mb-4 font-semibold text-center text-2xl text-chetwode-950 dark:text-chetwode-50"
      >
        Research Overview
      </h2>
      <div>
        <h3 class={sectionTitleClasses}>
          Field-based <span class={highlightedTextClasses}>evolutionary</span> studies
          of
          <span class={highlightedTextClasses2}>small mammals</span> in Indo-Australian
          Archipelago
        </h3>
      </div>
      <div class={sectionTitleClasses}>
        <h3>
          Improving <span class={highlightedTextClasses}>access</span> to
          <span class={highlightedTextClasses2}>cutting-edge</span> biodiversity research
        </h3>
      </div>
    </div>
    <div class={sectionTitleClasses}>
      <h3>
        Leveraging <span class={highlightedTextClasses}>emerging AI</span> technologies
        to understand <span class={highlightedTextClasses2}>complex</span> small mammal
        coloration
      </h3> -->
    <div>
      <div class={buttonClasses}>
        <a href="/projects">
          <p>Learn more</p>
        </a>
      </div>
    </div>
  </MainPage>
</Layout>
